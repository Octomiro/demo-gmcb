# ── Local development only ──
# Copy this file to .env and set your backend LAN IP.
# This is only used when running `npm run dev` (Vite dev server).
# In Docker, VITE_BACKEND_HOST is forcibly set to "" (empty) so the frontend
# uses relative URLs and nginx proxies all /api/* and /video_feed requests
# to the backend container automatically. Do NOT create a .env.production.
VITE_BACKEND_HOST=http://192.168.x.x:5000
