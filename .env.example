# ── Database ──
# These values are used by docker-compose for both the postgres container
# and the backend container. Copy this file to .env and fill in real values.
DB_NAME=farine_detection
DB_USER=farine_khomsa
DB_PASSWORD=change_me_strong_password

# ── Auth ──
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_64_hex_chars
